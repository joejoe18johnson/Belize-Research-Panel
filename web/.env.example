# Text logo (default on) — faster testing without PNG downloads. Set to false for image logos.
NEXT_PUBLIC_USE_TEXT_LOGO=true

AUTH_SESSION_SECRET=replace-with-a-long-random-string

# Enable demo logins and dev tooling on a staging/production Netlify site
ENABLE_DEMO_ACCOUNTS=true
NEXT_PUBLIC_ENABLE_DEMO_ACCOUNTS=true
ENABLE_POINTS_OVERRIDE=true

# Show the public Admin button on the home page (set false when staff use a private link only)
NEXT_PUBLIC_SHOW_ADMIN_ENTRY=true

# Resend transactional email (https://resend.com)
RESEND_API_KEY=
RESEND_FROM_EMAIL=Belize Research Panel <onboarding@resend.dev>

# Optional admin API key for contact-change approval routes
ADMIN_API_KEY=

# Admin console password (legacy super-admin fallback when email is left blank)
ADMIN_PASSWORD=
